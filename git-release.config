# Pro Wrestling Sim v3.0.0 - Git Release Configuration
# 
# This file contains default settings for git release scripts
# Edit these values to customize the release process
#
# Format: KEY=VALUE (no spaces around =)
# Lines starting with # are comments
# Empty lines are ignored

# ============================================================================
# RELEASE INFORMATION
# ============================================================================

# Commit message for the release
# This message will be used in git commit
COMMIT_MESSAGE=Release: Pro Wrestling Sim v3.0.0 - Build fixes and improvements

# Tag version for the release
# Should follow semantic versioning (e.g., v3.0.0, v3.0.1, etc.)
TAG_VERSION=v3.0.0

# Git branch to push to
# Usually "main" for production releases or "develop" for development
BRANCH=main

# ============================================================================
# GIT CONFIGURATION
# ============================================================================

# Remote repository name
# Usually "origin" for the default remote
REMOTE=origin

# Whether to create an annotated tag (true/false)
# Annotated tags are recommended for releases
CREATE_ANNOTATED_TAG=true

# Whether to delete existing tag if it already exists (true/false)
# Set to false to prevent accidental overwrites
DELETE_EXISTING_TAG=false

# ============================================================================
# WORKFLOW OPTIONS
# ============================================================================

# Automatically stage all changes before commit (true/false)
AUTO_STAGE=true

# Require user confirmation before executing (true/false)
REQUIRE_CONFIRMATION=true

# Display verbose output (true/false)
VERBOSE=false

# Perform dry run by default (true/false)
DRY_RUN=false

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================

# GitHub repository owner (username)
GITHUB_OWNER=Kreator8607

# GitHub repository name
GITHUB_REPO=wrestling-sim-desktop

# GitHub release URL (auto-generated, don't modify)
# GITHUB_RELEASE_URL=https://github.com/$GITHUB_OWNER/$GITHUB_REPO/releases

# ============================================================================
# NOTIFICATIONS
# ============================================================================

# Send notification after successful release (true/false)
SEND_NOTIFICATION=true

# Notification type: "email", "webhook", "none"
NOTIFICATION_TYPE=none

# Webhook URL for notifications (if NOTIFICATION_TYPE=webhook)
# WEBHOOK_URL=https://example.com/webhook

# Email address for notifications (if NOTIFICATION_TYPE=email)
# NOTIFICATION_EMAIL=user@example.com

# ============================================================================
# VALIDATION
# ============================================================================

# Check if working directory is clean before release (true/false)
CHECK_CLEAN_WORKING_DIR=true

# Check if branch exists before pushing (true/false)
CHECK_BRANCH_EXISTS=true

# Check if remote is reachable (true/false)
CHECK_REMOTE_REACHABLE=true

# ============================================================================
# ADVANCED OPTIONS
# ============================================================================

# Custom commit template file (leave empty to use default)
# COMMIT_TEMPLATE_FILE=

# Custom tag message template (leave empty to use default)
# TAG_MESSAGE_TEMPLATE=

# Additional git push options
# PUSH_OPTIONS=

# Additional git tag options
# TAG_OPTIONS=

# ============================================================================
# LOGGING
# ============================================================================

# Enable logging to file (true/false)
ENABLE_LOGGING=true

# Log file path
LOG_FILE=git-release.log

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# SCRIPT BEHAVIOR
# ============================================================================

# Exit on first error (true/false)
EXIT_ON_ERROR=true

# Show commands being executed (true/false)
SHOW_COMMANDS=false

# Pause after each step (true/false)
PAUSE_AFTER_STEPS=false

# ============================================================================
# CUSTOMIZATION
# ============================================================================

# Custom pre-release script to run before release
# Leave empty to skip
# PRE_RELEASE_SCRIPT=

# Custom post-release script to run after release
# Leave empty to skip
# POST_RELEASE_SCRIPT=

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
