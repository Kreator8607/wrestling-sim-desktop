# Pro Wrestling Sim v3.0.0 - GitHub Release Configuration
# 
# This file contains default settings for GitHub release scripts
# Edit these values to customize the release process
#
# Format: KEY=VALUE (no spaces around =)
# Lines starting with # are comments
# Empty lines are ignored

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================

# GitHub repository owner
GITHUB_OWNER=Kreator8607

# GitHub repository name
GITHUB_REPO=wrestling-sim-desktop

# GitHub personal access token (leave empty to use environment variable)
# GITHUB_TOKEN=

# ============================================================================
# RELEASE INFORMATION
# ============================================================================

# Release tag name (semantic versioning)
RELEASE_TAG=v3.0.0

# Release display name
RELEASE_NAME=Pro Wrestling Sim v3.0.0

# Release description (can be overridden with -b or -B flags)
RELEASE_BODY=Release of Pro Wrestling Sim v3.0.0 with Windows build, dynamic themes, animations, and improved UI.

# Path to release notes file (overrides RELEASE_BODY if set)
# RELEASE_BODY_FILE=CHANGELOG.md

# ============================================================================
# RELEASE OPTIONS
# ============================================================================

# Create as draft release (true/false)
# Draft releases are not visible to the public
DRAFT=false

# Mark as pre-release (true/false)
# Pre-releases are highlighted as not ready for production
PRERELEASE=false

# ============================================================================
# ASSET UPLOAD
# ============================================================================

# Upload assets from directory (leave empty to skip)
# UPLOAD_ASSETS_DIR=./dist

# Asset file patterns to upload (comma-separated)
# Examples: *.exe, *.zip, *.txt
ASSET_PATTERNS=*.exe,*.zip,checksums.txt

# ============================================================================
# SCRIPT BEHAVIOR
# ============================================================================

# Perform dry run by default (true/false)
DRY_RUN=false

# Require user confirmation before creating release (true/false)
REQUIRE_CONFIRMATION=true

# Verbose output (true/false)
VERBOSE=false

# ============================================================================
# API SETTINGS
# ============================================================================

# GitHub API base URL
GITHUB_API_URL=https://api.github.com

# API request timeout (seconds)
API_TIMEOUT=30

# Retry failed uploads (true/false)
RETRY_UPLOADS=true

# Maximum retry attempts
MAX_RETRIES=3

# ============================================================================
# NOTIFICATIONS
# ============================================================================

# Send notification after successful release (true/false)
SEND_NOTIFICATION=false

# Notification type: email, webhook, slack, discord
NOTIFICATION_TYPE=none

# Webhook URL for notifications
# WEBHOOK_URL=https://example.com/webhook

# Email address for notifications
# NOTIFICATION_EMAIL=user@example.com

# Slack webhook URL
# SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord webhook URL
# DISCORD_WEBHOOK=https://discordapp.com/api/webhooks/YOUR/WEBHOOK

# ============================================================================
# VALIDATION
# ============================================================================

# Check if tag exists before creating release (true/false)
CHECK_TAG_EXISTS=true

# Check if repository exists (true/false)
CHECK_REPO_EXISTS=true

# Verify GitHub token before creating release (true/false)
VERIFY_TOKEN=true

# ============================================================================
# CHANGELOG TEMPLATE
# ============================================================================

# Template for generating changelog
# Use {VERSION}, {DATE}, {AUTHOR} placeholders
CHANGELOG_TEMPLATE=## {VERSION} ({DATE})

Released by: {AUTHOR}

### Features
- Dynamic theme system based on promotion colors
- Framer Motion animations for UI interactions
- Modern wrestler card components
- Data visualization with Chart.js
- In-universe notification system
- Simulation feedback modal

### Improvements
- Build configuration fixes
- Performance optimizations
- Code organization

### Bug Fixes
- Fixed Electron build entry point
- Corrected GitHub Actions workflow

---

# ============================================================================
# RELEASE NOTES TEMPLATE
# ============================================================================

# Template for release notes
# Use {VERSION}, {DATE}, {CHANGES}, {CONTRIBUTORS} placeholders
RELEASE_NOTES_TEMPLATE=# Pro Wrestling Sim {VERSION}

**Release Date**: {DATE}

## What's New

{CHANGES}

## Installation

1. Download `Pro-Wrestling-Sim-{VERSION}.exe`
2. Run the installer
3. Follow the on-screen instructions

## System Requirements

- Windows 7 SP1 or later
- 2 GB RAM minimum
- 500 MB disk space
- Intel Core i3 or equivalent

## Contributors

{CONTRIBUTORS}

## Support

For issues or questions, please visit:
https://github.com/Kreator8607/wrestling-sim-desktop/issues

---

# ============================================================================
# ADVANCED OPTIONS
# ============================================================================

# Custom headers for API requests (JSON format)
# CUSTOM_HEADERS={"X-Custom-Header": "value"}

# Proxy settings (leave empty to disable)
# HTTP_PROXY=
# HTTPS_PROXY=

# SSL verification (true/false)
VERIFY_SSL=true

# ============================================================================
# LOGGING
# ============================================================================

# Enable logging to file (true/false)
ENABLE_LOGGING=true

# Log file path
LOG_FILE=github-release.log

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Maximum log file size (MB)
MAX_LOG_SIZE=10

# ============================================================================
# SCRIPT PATHS
# ============================================================================

# Path to bash script
BASH_SCRIPT=./github-release.sh

# Path to Python script
PYTHON_SCRIPT=./github-release.py

# Path to PowerShell script
POWERSHELL_SCRIPT=./github-release.ps1

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
