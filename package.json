    "react-dom": "^19.0.0",
    "react-router-dom": "^6.20.0",
    "wouter": "^3.0.0",
    "lucide-react": "^0.294.0"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "concurrently": "^8.2.2",
    "wait-on": "^7.0.1",
    "vitest": "^1.0.0"
  }
}
