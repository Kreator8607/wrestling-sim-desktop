{
  "name": "wrestling-sim-desktop",
  "version": "5.0.0-roadmap",
  "description": "Pro Wrestling Sim v4.0.0 - Desktop Application with Database Optimization",
    "main": "public/electron.js",
  "homepage": "./",
  "author": "Kreator8607",
  "license": "MIT",
  "scripts": {
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "copy-electron": "node -e \"const fs = require('fs'); fs.copyFileSync('src/main.js', 'build/electron.js');\"",
    "test": "vitest",
    "build:win": "npm run react-build && npm run copy-electron && electron-builder --win --publish never",
    "build": "npm run build:win"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.294.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.20.0",
    "sql.js": "^1.8.0",
    "wouter": "^3.0.0"
  },
  "devDependencies": {
    "asar": "^3.2.0",
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "electron-is-dev": "^3.0.1",
    "react-scripts": "5.0.1",
    "vitest": "^1.0.0",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.wrestling-sim.app",
    "productName": "Pro Wrestling Sim",
    "directories": {
      "buildResources": "public",
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "public/electron.js",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": null,
      "sign": null,
      "publisherName": "Pro Wrestling Sim"
    },

    "portable": {
      "artifactName": "${productName}-${version}.exe"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
