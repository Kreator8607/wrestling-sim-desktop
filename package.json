{
  "name": "wrestling-sim-desktop",
  "version": "3.0.0",
  "description": "Pro Wrestling Simulator - Desktop Application",
  "main": "dist/main.js",
  "homepage": "./",
  "author": "Kreator8607",
  "license": "MIT",
  "scripts": {
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
